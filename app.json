{
  "expo": {
    "name": "The Chameleon",
    "slug": "chameleon",
    "version": "1.2.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0c130d",
    "androidStatusBar": {
      "backgroundColor": "#0c130d",
      "barStyle": "light-content",
      "translucent": false
    },
    "splash": {
      "backgroundColor": "#0c130d"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0c130d"
      },
      "package": "com.chameleon.passandplay",
      "versionCode": 4,
      "softwareKeyboardLayoutMode": "pan"
    },
    "ios": {
      "bundleIdentifier": "com.chameleon.passandplay",
      "supportsTablet": false
    },
    "plugins": [
      "expo-asset",
      "expo-status-bar"
    ],
    "extra": {
      "eas": {
        "projectId": "87fb0f00-76a3-480f-815c-7f22af58b424"
      }
    },
    "owner": "snypers-team"
  }
