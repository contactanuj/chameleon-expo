{
  "name": "chameleon",
  "version": "1.2.0",
  "description": "The Chameleon - pass-and-play companion app (Word + Picture editions, fully configurable, with offline bots). Unofficial fan-made.",
  "main": "node_modules/expo/AppEntry.js",
  "license": "MIT",
  "author": "Anuj Pratap Singh <anujjadon98@gmail.com>",
  "homepage": "https://github.com/contactanuj/chameleon-expo#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/contactanuj/chameleon-expo.git"
  },
  "bugs": {
    "url": "https://github.com/contactanuj/chameleon-expo/issues"
  },
  "keywords": [
    "chameleon",
    "party-game",
    "social-deduction",
    "board-game",
    "pass-and-play",
    "expo",
    "react-native",
    "android"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build:html": "node build.js",
    "eas-build-post-install": "node build.js",
    "test": "node tests/engine.test.js && node tests/bots.test.js && node tests/ui.test.js",
    "test:engine": "node tests/engine.test.js",
    "test:bots": "node tests/bots.test.js",
    "test:ui": "node tests/ui.test.js",
    "start": "npm run build:html && expo start",
    "android": "npm run build:html && expo run:android",
    "ios": "npm run build:html && expo run:ios",
    "build:android": "npm run build:html && npx eas-cli build -p android --profile preview"
  },
  "dependencies": {
    "expo": "^56.0.11",
    "expo-asset": "~56.0.17",
    "expo-file-system": "~56.0.8",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-webview": "13.16.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0"
  }
}
